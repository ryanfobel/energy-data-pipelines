# Open Data Coop Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git!

# Home Assistant / InfluxDB configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=home_assistant

# Alternative: Path to Home Assistant parquet export
HA_PARQUET_FILE=/path/to/home_assistant_power_monitoring.parquet

# Green Button XML files directory
GREEN_BUTTON_DIR=/path/to/greenbutton/files

# Optional: API tokens for utility providers
HYDRO_ONE_API_KEY=your-api-key-here
ENBRIDGE_API_KEY=your-api-key-here

# Optional: Cloud storage credentials (for syncing Paimon warehouse)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1

# Optional: Database connections
POSTGRES_URL=postgresql://user:password@localhost:5432/energy_data
